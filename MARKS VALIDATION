col = "HITS"

class AIML:
    dept = "artificial"

    def set_dim(self, a, b, c, d):
        self.m1 = a
        self.m2 = b
        self.m3 = c
        self.name = d

    def display(self):
        print("1. Name:", self.name)
        print("2. Average:", (self.m1 + self.m2 + self.m3) // 3)
        print("3. Dept:", AIML.dept)
        print("4. College:", col)


