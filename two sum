class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
    def twoSum(self, num: List[int], target: int) -> List[int]:
        d={}
        for i in range(len(num)):
            rem=target-num[i]
            if rem in d:
                return[d[rem],i]
            d[num[i]]=i
        
