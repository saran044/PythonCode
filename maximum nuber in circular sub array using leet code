class Solution(object):
    def maxSubarraySumCircular(self, nums):
      c_max=nums[0]
      c_min=nums[0]
      x=nums[0]
      y=nums[0]
      tot=nums[0]
      for i in range(1,len(nums)):
        c_max=max(nums[i],c_max+nums[i])
        c_min=min(nums[i],c_min+nums[i])
        x=max(x,c_max)
        y=min(y,c_min)
        tot=tot+nums[i]
      z=tot-y
      if x<0: 
        return x
      return max(x,z)     
