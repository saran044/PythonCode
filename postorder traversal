lass Solution:
    def __init__(self):
        self.res=[]
    def postorderTraversal(self, root: Optional[TreeNode]) -> List[int]:
        if root is None:
            return self.res
        self.postorderTraversal(root.left)
        self.postorderTraversal(root.right)
        self.res.append(root.val)
        return self.res

        
